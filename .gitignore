# Dependencies
node_modules/
package-lock.json

# Environment files with real secrets — never commit these
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local


# .env.example files are intentionally committed (no real secrets)
!.env.example
!backend/.env.example
!frontend/.env.example

# Python
backend/.venv/
**/__pycache__/
*.py[cod]
*.egg-info/

# Session data (ephemeral runtime files)
sessions/
/tmp/obsidian-sessions/

# Redis persistence files (runtime artifacts)
dump.rdb
*.rdb

# Next.js build output
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# OS / editor
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
output/