# NextAuth secret — required for JWT signing
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# LLM provider — supported: anthropic | openai | gemini | lmstudio  (default: anthropic)
AI_PROVIDER=anthropic

# Override the default model for the chosen provider (optional)
# Anthropic default : claude-sonnet-4-6
# OpenAI default    : gpt-4o
# Gemini default    : gemini-2.5-flash
# LM Studio default : local-model  (set to whatever you loaded in LM Studio)
# AI_MODEL=claude-sonnet-4-6

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_key_here

# Google Gemini — https://aistudio.google.com/app/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_key_here

# LM Studio — no key required; set the server URL if not using default port
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_API_KEY=lm-studio
