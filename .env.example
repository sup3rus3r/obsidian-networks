# LLM provider — supported: anthropic | openai | lmstudio  (default: anthropic)
AI_PROVIDER=anthropic

# Override the default model for the chosen provider (optional)
# AI_MODEL=claude-sonnet-4-6

# API keys — only the active provider's key is required
ANTHROPIC_API_KEY=your_anthropic_key_here   # https://console.anthropic.com
# OPENAI_API_KEY=your_openai_key_here        # https://platform.openai.com/api-keys
# LMSTUDIO_BASE_URL=http://localhost:1234/v1  # default LM Studio port
# LMSTUDIO_API_KEY=lm-studio                  # no real key needed

# Auth secret — required. Generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# Backend settings (defaults shown)
REDIS_URL=redis://redis:6379/0
MONGO_URL=mongodb://mongo:27017   # set automatically in Docker; override for Atlas
MONGO_DB_NAME=obsidian
SESSION_TTL_HOURS=4
MAX_FILE_SIZE_MB=500
SESSIONS_DIR=/sessions
MAX_TRAINING_MINUTES=240
MAX_MEMORY_GB=12
MAX_OUTPUT_GB=10
MAX_EPOCHS=200

# Direct browser→backend URL for large file uploads (bypasses Next.js proxy buffering)
# In Docker: set to http://localhost:8000 (backend exposed on host port 8000)
NEXT_PUBLIC_UPLOAD_URL=http://localhost:8000

# GPU / accelerator settings
# Priority order: local_docker → runpod → lambda_labs → cpu_fallback (always)
#
# Option 1 — Local Docker GPU (requires nvidia-docker2 / --gpus support on the host)
# TRAINING_DOCKER_IMAGE=obsidian-trainer:latest   # pre-built training image
# RESEARCH_ARTIFACTS_DIR=/research_artifacts      # where job outputs are stored
#
# Option 2 — RunPod serverless (requires a deployed RunPod worker image)
# RUNPOD_API_KEY=your_runpod_key_here             # https://www.runpod.io/console/user/settings
# RUNPOD_ENDPOINT_ID=your_endpoint_id             # serverless endpoint ID from RunPod console
#
# Option 3 — Lambda Labs on-demand GPU
# LAMBDA_API_KEY=your_lambda_key_here             # https://cloud.lambdalabs.com/api-keys
#
# Polling interval for checking remote job status (default: 15s)
# GPU_POLL_INTERVAL_S=15
